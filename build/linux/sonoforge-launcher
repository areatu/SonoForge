#!/usr/bin/env bash
# ============================================
#  SonoForge Launcher
#  Checks environment, installs deps/models if needed, then launches.
# ============================================
set -euo pipefail

APP_NAME="sonoforge"
DATA_DIR="${HOME}/.local/share/${APP_NAME}"
VENV_DIR="${DATA_DIR}/venv"
MODELS_DIR="${DATA_DIR}/models"
LIB_DIR="/opt/${APP_NAME}/lib"
PYTHON_MIN="3.10"
MODELS_RELEASE_URL="https://github.com/areatu/sonoforge-models/releases/download/models-v1/models-v1.tar.gz"

# ── Colors ──
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { echo -e "${CYAN}[SonoForge]${NC} $*"; }
ok()    { echo -e "${GREEN}[SonoForge]${NC} $*"; }
warn()  { echo -e "${YELLOW}[SonoForge]${NC} $*"; }
err()   { echo -e "${RED}[SonoForge]${NC} $*" >&2; }

# ── 1. Find Python ──
find_python() {
    local candidates=("python3.11" "python3.10" "python3")
    for cmd in "${candidates[@]}"; do
        if command -v "$cmd" &>/dev/null; then
            local ver
            ver=$("$cmd" -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null)
            if [ -n "$ver" ]; then
                local major minor
                major=$(echo "$ver" | cut -d. -f1)
                minor=$(echo "$ver" | cut -d. -f2)
                if [ "$major" -ge 3 ] && [ "$minor" -ge 10 ]; then
                    echo "$cmd"
                    return 0
                fi
            fi
        fi
    done
    return 1
}

PYTHON=$(find_python) || {
    err "Python ${PYTHON_MIN}+ not found."
    err "Install: sudo apt install python3 python3-venv python3-pip"
    exit 1
}
info "Using: $PYTHON ($($PYTHON --version 2>&1))"

# ── 2. Create venv if missing ──
if [ ! -d "${VENV_DIR}" ]; then
    info "Creating virtual environment..."
    mkdir -p "${DATA_DIR}"
    $PYTHON -m venv "${VENV_DIR}"
    ok "venv created at ${VENV_DIR}"
fi

VENV_PYTHON="${VENV_DIR}/bin/python"
VENV_PIP="${VENV_DIR}/bin/pip"

# ── 3. Install/upgrade dependencies ──
REQ_FILE="${LIB_DIR}/pyproject.toml"
MARKER="${VENV_DIR}/.deps_installed"

NEED_INSTALL=false
if [ ! -f "${MARKER}" ]; then
    NEED_INSTALL=true
elif [ "${REQ_FILE}" -nt "${MARKER}" ] 2>/dev/null; then
    NEED_INSTALL=true
fi

if [ "${NEED_INSTALL}" = true ]; then
    info "Installing dependencies (this may take a few minutes)..."
    "${VENV_PIP}" install --quiet --upgrade pip 2>/dev/null

    if [ -f "${REQ_FILE}" ]; then
        "${VENV_PIP}" install --quiet -e "${LIB_DIR}" 2>/dev/null \
            || "${VENV_PIP}" install --quiet \
                pyside6 pyqtgraph pydicom pylibjpeg pylibjpeg-openjpeg pylibjpeg-libjpeg \
                "numpy<2" scipy opencv-python-headless httpx psutil pymupdf pynetdicom \
                pyyaml jsonschema onnxruntime reportlab openpyxl keyring
    else
        "${VENV_PIP}" install --quiet \
            pyside6 pyqtgraph pydicom pylibjpeg pylibjpeg-openjpeg pylibjpeg-libjpeg \
            "numpy<2" scipy opencv-python-headless httpx psutil pymupdf pynetdicom \
            pyyaml jsonschema onnxruntime reportlab openpyxl keyring
    fi

    touch "${MARKER}"
    ok "Dependencies installed."
else
    ok "Dependencies up to date."
fi

# ── 4. Download models if missing ──
download_models() {
    local MAX_RETRIES=3
    local DOWNLOAD_OK=false

    for attempt in $(seq 1 $MAX_RETRIES); do
        info "Attempt ${attempt}/${MAX_RETRIES}..."
        if command -v curl &>/dev/null; then
            if curl -fSL --connect-timeout 30 --retry 2 --progress-bar \
                -o "${DATA_DIR}/models.tar.gz" "${MODELS_RELEASE_URL}"; then
                DOWNLOAD_OK=true
                break
            fi
        elif command -v wget &>/dev/null; then
            if wget --timeout=30 --tries=2 --show-progress \
                -O "${DATA_DIR}/models.tar.gz" "${MODELS_RELEASE_URL}"; then
                DOWNLOAD_OK=true
                break
            fi
        else
            err "Neither curl nor wget found. Install one and retry."
            return 1
        fi
        warn "Download failed, retrying in 5s..."
        sleep 5
    done

    if [ "${DOWNLOAD_OK}" = false ]; then
        err "Model download failed after ${MAX_RETRIES} attempts."
        err "Download manually: ${MODELS_RELEASE_URL}"
        err "Extract to: ${MODELS_DIR}/"
        rm -f "${DATA_DIR}/models.tar.gz"
        return 1
    fi

    info "Extracting models..."
    tar xzf "${DATA_DIR}/models.tar.gz" -C "${DATA_DIR}/"
    rm -f "${DATA_DIR}/models.tar.gz"

    if [ -f "${MODELS_DIR}/model_manifest.json" ]; then
        ok "Models ready."
        return 0
    else
        err "Extraction failed. Models will be unavailable."
        warn "You can manually place models in ${MODELS_DIR}/"
        return 1
    fi
}

if [ ! -f "${MODELS_DIR}/model_manifest.json" ]; then
    info "Downloading models (~300 MB)..."
    mkdir -p "${MODELS_DIR}"
    download_models || true
else
    ok "Models found."
fi

# ── 5. Launch ──
export PYTHONPATH="${LIB_DIR}:${PYTHONPATH:-}"
exec "${VENV_PYTHON}" -m echo_personal_tool "$@"
